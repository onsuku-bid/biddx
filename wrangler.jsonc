{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "webapp",
  "compatibility_date": "2026-04-02",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ]
  // 環境変数はCloudflareダッシュボード or wrangler secret put で設定
  // ローカル開発時は .dev.vars に記載
  // RESEND_API_KEY=re_xxxx
  // NOTIFY_EMAILS=xxx@example.com,yyy@example.com
  // NOTIFY_KEYWORDS=動画制作,研修
  // NOTIFY_SECRET=bid-notify-2024
}
